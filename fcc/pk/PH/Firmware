<script>
   // dropdown
   const dropDown = document.querySelectorAll(".accordion4");

   for (let i = 0; i < dropDown.length; i++) {
      dropDown[i].addEventListener("click", function () {
         this.classList.toggle("active");
         let panel4 = this.nextElementSibling;
         if (panel4.style.display == "block") {
            panel4.style.display = "none";
         } else {
            panel4.style.display = "block";
         }
      });
   }

   // Get the modal
   const modals = document.querySelectorAll(".modal");

   // get buttons
   const btns = document.querySelectorAll("button.custom-btn");

   const showModal = (id) => {
      let m = document.getElementById(id);
      m.classList.add("visible");
   };

   const hideModals = () => {
      modals.forEach((m) => {
         m.classList.remove("visible");
      });
   };

   btns.forEach((b) => {
      b.addEventListener("click", (event) => {
         hideModals();
         showModal(b.dataset.modal);
      });
   });

   modals.forEach((m) => {
      let x = m.querySelector("span.close");
      x.addEventListener("click", hideModals);
   });
</script>
